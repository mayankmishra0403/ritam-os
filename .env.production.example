# =============================================================================
# Ritam OS — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
#   cp .env.production.example .env
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=ritam
DB_PASSWORD=change-this-to-random-password
DB_NAME=ritam_prod

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-this-to-random-redis-password

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-random-string-here-for-security
JWT_EXPIRES_IN=7d

# ── MSG91 WhatsApp ───────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_NUMBER=919305804916

# ── Razorpay (when available) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── API Port ─────────────────────────────────────────────────────────────────
API_PORT=4000

# ── Digital Ocean (for GitHub Actions secrets — NOT in .env on the server) ──
DO_HOST=your-droplet-ip
DO_USER=root
DO_SSH_KEY=your-ssh-private-key

# ── Vercel (for GitHub Actions secrets — NOT in .env on the server) ─────────
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID_WEB=your-vercel-project-id-for-web
VERCEL_PROJECT_ID_POS=your-vercel-project-id-for-pos
VERCEL_PROJECT_ID_QR=your-vercel-project-id-for-qr-ordering
